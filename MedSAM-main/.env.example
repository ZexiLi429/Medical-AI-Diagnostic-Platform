# 环境配置文件 - 复制为 .env 并填入实际的API密钥

# ===== LLM API 配置 =====
# OpenAI配置 (用于GPT-4, GPT-4 Vision)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic配置 (用于Claude 3)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== MedSAM模型配置 =====
# 模型检查点路径
MEDSAM_CHECKPOINT=work_dir/MedSAM/medsam_vit_b.pth

# 设备配置
DEVICE=cuda  # 或 cpu

# ===== 服务端口配置 =====
MEDSAM_PORT=8000
LLM_SERVICE_PORT=8001

# ===== CORS配置 =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8042

# ===== 日志配置 =====
LOG_LEVEL=INFO
